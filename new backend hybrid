});

/**
 * Extract skills from messy work history.
 *
 * Example input:
 * {
 *   "workHistoryText": "I track inventory in Excel, SAP, and Power BI..."
 * }
 */

app.post("/api/extract-skills", async (req, res) => {
  try {
    const { workHistoryText } = ExtractSkillsSchema.parse(req.body);

    const response = await runAI({
      task: "extract_skills",
      messages: [
        {
          role: "system",
          content: latticeSystemPrompt() + jsonOnlyInstruction(),
        },
        {
          role: "user",
          content: `
Extract structured career data from this user's work history.

Work history:
${workHistoryText}

Return JSON with this shape:

{
  "provenSkills": [
    {
      "skill": "",
      "evidence": "",
      "category": "technical | operations | communication | leadership | analytics | industry | other",
      "confidence": "high | medium | low"
    }
  ],
  "likelySkillsToVerify": [
    {
      "skill": "",
      "whyLikely": "",
      "questionToConfirm": ""
    }
  ],
  "toolsAndSystems": [],
  "businessFunctions": [],
  "strongResumeAngles": [],
  "missingDetailsToAsk": [],
  "possibleTargetRoles": [
    {
      "role": "",
      "why": "",
      "readiness": "strong | moderate | stretch"
    }
  ]
}
`,
        },
      ],
      temperature: 0.1,
      maxTokens: 1600,
    });

    res.json(response);
  } catch (error: any) {
    res.status(400).json({
      error: error.message || "Failed to extract skills",
    });
  }
});

