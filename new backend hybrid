/**
 * Career coach chatbot.
 */

app.post("/api/career-coach", async (req, res) => {
  try {
    const { userProfile, message, history } = CareerCoachSchema.parse(req.body);

    const profileText = userProfile
      ? `
User profile:
${JSON.stringify(userProfile, null, 2)}
`
      : "No user profile provided.";

    const messages: AIMessage[] = [
      {
        role: "system",
        content: latticeSystemPrompt(),
      },
      ...(history || []).map((m) => ({
        role: m.role,
        content: m.content,
      })),
      {
        role: "user",
        content: `
${profileText}

User message:
${message}
`,
      },
    ];

    const response = await runAI({
      task: "career_coach",
      messages,
      temperature: 0.4,
      maxTokens: 1400,
    });

    res.json(response);
  } catch (error: any) {
    res.status(400).json({
      error: error.message || "Failed to run career coach",
    });
  }
});

